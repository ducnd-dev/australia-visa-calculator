# =============================================================================
# Australia Visa Calculator — Environment template
# =============================================================================
#
# Quick start:
#   npm run setup:env        # copy → .env.local + .env, auto webhook secrets
#   npm run setup:env:sync   # merge new keys from this file into .env.local
#
# Where to put values:
#   LOCAL (.env.local)     — dev machine + npm scripts (db:migrate, beta:*)
#   VERCEL (Production)    — paste same keys except "Scripts only" section
#   BOTH                   — required in .env.local AND Vercel for that feature
#
# Never commit .env or .env.local (real secrets). This file is safe to commit.
#
# Docs: docs/HUONG-DAN-LAY-KEY.md · Vercel checklist: npm run print:vercel-env
# =============================================================================

# -----------------------------------------------------------------------------
# App — BOTH (local + Vercel)
# Feature: share links, invite URLs, Stripe redirect, sitemap, SEO
# -----------------------------------------------------------------------------
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Vercel): https://your-app.vercel.app  OR  https://yourdomain.com.au
# (no trailing slash)

# Feature: contact page + support inbox (optional)
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com.au

# Display price on /pricing (optional; falls back to Stripe price)
NEXT_PUBLIC_AGENCY_PRICE_DISPLAY=

# -----------------------------------------------------------------------------
# Supabase Auth + Database — BOTH
# Feature: /login, /app, clients, assessments, share, team invites
# Get keys: Supabase → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Use ONE of anon OR publishable (new Supabase projects may use publishable):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server only — NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Supabase migrations — LOCAL ONLY (npm run db:migrate)
# Not needed on Vercel runtime. Use Session pooler port 5432, not 6543.
# Supabase → Settings → Database → Connection string (Session mode)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres
# Or build URL from password + project ref:
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=

# -----------------------------------------------------------------------------
# Resend Email — BOTH
# Feature: team invite, assessment report, marketing campaigns, domain verify
# Get key: resend.com → API Keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# Auto-generated by npm run setup:env (local). Match in Resend webhook header.
RESEND_WEBHOOK_SECRET=

# Dev / beta (Option A): onboarding@resend.dev — only sends to Resend account email
# Production (Option B): reports@yourdomain.com.au — after domain verify in Resend
EMAIL_FROM_PLATFORM="Visa Calculator <onboarding@resend.dev>"
EMAIL_FROM_DEFAULT_AGENCY="via Visa Calculator <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# Stripe Billing — BOTH
# Feature: /app/billing upgrade, Agency plan, PDF + branded share unlock
# Test mode (sk_test_/pk_test_) for local; live keys on Vercel production
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_AGENCY_MONTHLY=

# Webhook URL (configure in Stripe dashboard after deploy):
#   {NEXT_PUBLIC_SITE_URL}/api/stripe/webhook
# Local: stripe listen --forward-to localhost:3000/api/stripe/webhook

# -----------------------------------------------------------------------------
# OpenAI — BOTH (server uses key; optional for AI explain feature)
# Feature: AI explain on assessment breakdown (does NOT calculate points)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
AI_MODEL_DEFAULT=gpt-4o-mini

# -----------------------------------------------------------------------------
# Cloudflare R2 — BOTH (secrets server-side; public URL is NEXT_PUBLIC_*)
# Feature: agency logo upload, branded share/PDF
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=australia-visa-files
R2_KEY_PREFIX=org-logos
NEXT_PUBLIC_R2_PUBLIC_URL=
# Server fallback if NEXT_PUBLIC not set:
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Analytics & ads — BOTH (optional, public site only)
# Feature: GA4 pageviews; AdSense on marketing pages (not /app)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Launch / QA scripts — LOCAL ONLY (do not add to Vercel)
# Used by: setup:launch-g2, beta:test-email, beta:smoke, beta:complete-gates
# -----------------------------------------------------------------------------
# Inbox for npm run beta:test-email (use Resend account email for Option A)
BETA_TEST_EMAIL=

# Override smoke target without changing SITE_URL (production smoke after deploy)
SMOKE_BASE_URL=

# One-shot G2 setup: RESEND_API_KEY=re_xxx LAUNCH_SITE_URL=https://... npm run setup:launch-g2
LAUNCH_SITE_URL=

# Known production deploy (for gate-status / smoke when local SITE_URL is localhost)
PRODUCTION_SITE_URL=https://australia-visa-calculator.vercel.app
